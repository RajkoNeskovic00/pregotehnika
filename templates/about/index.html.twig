{% extends 'base.html.twig' %}

{% block title %}
    O nama | Pregotehnika
{% endblock %}

{% block body %}

<section class="about-section">

    <div class="about-overlay"></div>

    <div class="container position-relative">

        <div class="text-center mb-5 about-header">

            <h1 class="fw-bold">
                O nama
            </h1>

            <p>
                Preciznost, iskustvo i pouzdana industrijska rešenja
            </p>

        </div>

        <div class="about-content shadow-sm">

            <div class="about-block">

                <h3>
                    Pregotehnika
                </h3>

                <p>
                    <strong>Pregotehnika</strong> je uskospecijalizovana kompanija sa više od
                    <span class="highlight">tri decenije iskustva</span> u projektovanju i izradi
                    <strong>graviranih valjaka</strong> za različite industrijske primene.

                    U zavisnosti od tehnoloških zahteva kupaca izrađujemo
                    <span class="highlight">pojedinačne gravirane valjke</span> i kompletne sklopove
                    namenjene papirnoj industriji, industriji prerade plastičnih materijala,
                    proizvodnji ambalaže od aluminijumskih folija, kao i auto-industriji.
                </p>

            </div>

            <div class="about-stats">
                <div class="stat-box">
                    <strong>2004.</strong>
                    <span>Godina osnivanja</span>
                </div>
                <div class="stat-box">
                    <strong>25+</strong>
                    <span>Godina iskustva</span>
                </div>
                <div class="stat-box">
                    <strong>100%</strong>
                    <span>Posvećenost kvalitetu</span>
                </div>
            </div>

            <div class="about-block">

                <h3>
                    Tehnologija i kvalitet
                </h3>

                <p>
                    Primena <strong>savremenih tehnologija</strong> i tradicionalnih tehnika
                    graviranja omogućava izradu površinskih struktura visokog kvaliteta.

                    Svakom projektu pristupamo
                    <span class="highlight">individualno i precizno</span>,
                    sa ciljem da ponudimo pouzdano i dugotrajno rešenje prilagođeno
                    zahtevima svakog proizvodnog procesa.
                </p>

            </div>

            <div class="about-block">
                <h3>
                    Kompletna industrijska rešenja
                </h3>
                <p>
                    Pored proizvodnje graviranih valjaka, projektujemo, izrađujemo i montiramo
                    <strong>kompletne linije za preradu toalet papira</strong>.

                    Naša rešenja obuhvataju kompletan proces:
                    <span class="highlight">
                        razvoj, proizvodnju, montažu i puštanje opreme u rad.
                    </span>
                </p>
            </div>
            <div class="about-block">
                <h3>
                    Pouzdan partner industrije
                </h3>
                <p>
                    Naši proizvodi i tehnološka rešenja koriste se kod kupaca u zemlji i inostranstvu.
                    Prepoznati smo po <strong>kvalitetu izrade, preciznosti i dugom radnom veku</strong>.

                    Dugogodišnje iskustvo i posvećenost svakom projektu čine nas pouzdanim partnerom
                    u unapređenju proizvodnih procesa.
                </p>
            </div>
        </div>

        {# Galerija #}
        <div class="about-gallery mt-5">

            <h2 class="text-center mb-4 text-white">
                Naši proizvodi i proizvodnja
            </h2>

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="gallery-item">
                        <img src="/images/about/ekstruzija_plasticnih_masa.jpg" alt="Gravirani valjak">
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="gallery-item">
                        <img src="/images/about/medicinske_komprese_eos.jpg" alt="Industrijski valjak">
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="gallery-item">
                        <img src="/images/about/papirne_maramice.jpg" alt="Proizvodnja">
                    </div>
                </div>
                 <div class="col-md-4">
                    <div class="gallery-item">
                        <img src="/images/about/salvete.jpg" alt="Proizvodnja">
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="gallery-item">
                        <img src="/images/about/sklop.jpg" alt="Proizvodnja">
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{% endblock %}
